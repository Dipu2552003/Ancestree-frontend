# Frontend (Next.js) — set these in the Vercel project's Environment Variables.
# NEXT_PUBLIC_* values are baked into the client bundle at build time.
# Never commit a real .env.production file — set values in the Vercel dashboard.

# Prod values (scope to Production branch: main)
NEXT_PUBLIC_API_URL=https://api.knownyourancestry.com
NEXT_PUBLIC_FAMILYGRAPH_URL=https://3d.knownyourancestry.com

# Dev values (scope to Preview branch: dev)
# NEXT_PUBLIC_API_URL=https://dev.api.knownyourancestry.com
# NEXT_PUBLIC_FAMILYGRAPH_URL=https://3d.knownyourancestry.com
